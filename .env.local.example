# ─────────────────────────────────────────────
# VTO Vertex — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Google Cloud Project ID (from Google Cloud Console)
GOOGLE_CLOUD_PROJECT="gen-lang-client-0044079183"

# Vertex AI region (must support virtual-try-on-001 model — us-central1 recommended)
GOOGLE_CLOUD_LOCATION="us-central1"

# Absolute path to your Google Cloud service account JSON key file
# Download it from: IAM & Admin → Service Accounts → Keys → Add Key (JSON)
GOOGLE_APPLICATION_CREDENTIALS="C:/path/to/your/service-account-key.json"
